{
  "name": "task/rest-sdk",
  "description": "Framework-agnostic REST API SDK client library",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "ext-json": "*",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.0",
    "psr/http-message": "^2.0",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.65",
    "nyholm/psr7": "^1.8",
    "php-http/mock-client": "^1.6",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "RestSDK\\": "src/",
      "Example\\": "example/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  }
}
